{
  "name": "cotaska",
  "version": "0.2.1",
  "description": "Cotaska - ローカルタスク管理システム",
  "main": "src/main/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "start": "electron .",
    "dist:installer": "npm run build && electron-builder --win nsis --publish never",
    "dist:portable": "npm run build && electron-builder --win portable --publish never",
    "dist:dir": "npm run build && electron-builder --win dir --publish never"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@vitejs/plugin-react": "^6.0.1",
    "electron": "^41.0.2",
    "electron-builder": "^26.0.12",
    "vite": "^8.0.0"
  },
  "build": {
    "appId": "com.cotaska.app",
    "productName": "CotaskaCore",
    "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
    "directories": {
      "output": "release"
    },
    "files": [
      "**/*",
      "!release/**",
      "!temp/**",
      "!setup/node_modules/**",
      "!*.log"
    ],
    "extraResources": [
      {
        "from": "setup/launcher/icon.ico",
        "to": "icon.ico"
      }
    ],
    "asar": true,
    "publish": [
      {
        "provider": "github",
        "owner": "csho10051",
        "repo": "Agent_Cotaska",
        "releaseType": "release"
      }
    ],
    "win": {
      "icon": "setup/launcher/icon.ico",
      "signAndEditExecutable": false,
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "deleteAppDataOnUninstall": false
    }
  },
  "dependencies": {
    "adm-zip": "^0.5.17",
    "chokidar": "^3.6.0",
    "electron-updater": "^6.8.3",
    "gray-matter": "^4.0.3",
    "js-yaml": "^4.1.1",
    "markdown-it": "^14.1.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  }
}
